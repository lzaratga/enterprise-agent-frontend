# ============================================================================
# ENTERPRISE AI AGENT - FRONTEND ENVIRONMENT VARIABLES
# ============================================================================

# API Backend URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# ServiceNow Configuration
NEXT_PUBLIC_SERVICENOW_INSTANCE=https://dev12345.service-now.com
NEXT_PUBLIC_OAUTH_CLIENT_ID=your_client_id_here

# Optional: Analytics and Monitoring
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_ANALYTICS_ID=

# Optional: Feature Flags
# NEXT_PUBLIC_ENABLE_DARK_MODE=true
# NEXT_PUBLIC_ENABLE_AI_CHAT=true
# NEXT_PUBLIC_ENABLE_AUTO_CLASSIFICATION=true

# ============================================================================
# PRODUCTION NOTES
# ============================================================================
# 1. Never commit .env.local to git
# 2. Use Vercel/platform environment variables for production
# 3. Keep sensitive data in backend, not frontend env vars
# 4. All NEXT_PUBLIC_ vars are exposed to the browser
# ============================================================================
